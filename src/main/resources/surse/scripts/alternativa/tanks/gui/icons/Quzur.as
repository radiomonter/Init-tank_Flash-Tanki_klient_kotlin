package alternativa.tanks.gui.icons
{
   import flash.display.Bitmap;
   import flash.display.BitmapData;
   
   public class Quzur
   {
      
      private static const premiumIconClass:Class = Gyqyl;
      
      private static const bykic:BitmapData = new premiumIconClass().bitmapData;
      
      private static const waz:Class = Qogiwyt;
      
      private static const nabumidi:BitmapData = new waz().bitmapData;
      
      public function Quzur()
      {
         super();
      }
      
      public static function createInstance() : Bitmap
      {
         return new Bitmap(bykic);
      }
      
      public static function createSmallInstance() : Bitmap
      {
         return new Bitmap(nabumidi);
      }
   }
}

